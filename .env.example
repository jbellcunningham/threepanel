NODE_ENV=production
PORT=3000

# Public app URL (used by frontend/runtime where needed)
NEXT_PUBLIC_APP_URL=https://app.es1creative.com

# Postgres service credentials used by docker-compose.prod.yml
POSTGRES_DB=threepanel
POSTGRES_USER=threepanel
POSTGRES_PASSWORD=change-me-strong-password

# Prisma connection string for the app container
# Uses compose service name "db" as host.
DATABASE_URL=postgresql://threepanel:change-me-strong-password@db:5432/threepanel?schema=public

# Web Push (PWA notifications)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT_EMAIL=admin@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
