generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  TESTER
  REPORTING
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trackers        TrackerItem[]
  containerAccess ContainerAccess[]
  sessions        Session[]
  settings        UserSettings?
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  appTitle           String?
  theme              String?
  hiddenSidebarTypes Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrackerItem {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("tracker")
  title     String
  notes     String?
  // Schema-driven tracker: user-defined field definitions live here
  schema    Json?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries         TrackerEntry[]
  containerAccess ContainerAccess[]

  @@index([userId])
}

model TrackerEntry {
  id        String @id @default(cuid())
  trackerId String

  // Schema-driven tracker: entry values (fieldId -> value) live here
  data Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tracker TrackerItem @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@index([trackerId])
}

model ContainerAccess {
  id            String   @id @default(cuid())
  userId        String
  trackerItemId String
  accessType    String   @default("read")
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackerItem TrackerItem @relation(fields: [trackerItemId], references: [id], onDelete: Cascade)

  @@unique([userId, trackerItemId, accessType])
  @@index([userId])
  @@index([trackerItemId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
