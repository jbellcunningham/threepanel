generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  todos          TodoItem[]
  trackers       TrackerItem[]
  journalEntries JournalEntry[]
  sessions       Session[]
}

model TodoItem {
  id        String    @id @default(cuid())
  userId    String
  title     String
  done      Boolean   @default(false)
  dueAt     DateTime?
  listPosition     Int      @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, done])
}

model TrackerItem {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("tracker")
  title     String
  notes     String?
  // Schema-driven tracker: user-defined field definitions live here
  schema   Json?
  done     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries TrackerEntry[]

  @@index([userId])
}

model TrackerEntry {
  id        String   @id @default(cuid())
  trackerId String

  // Schema-driven tracker: entry values (fieldId -> value) live here
  data      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tracker   TrackerItem @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@index([trackerId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  entryDate DateTime
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
